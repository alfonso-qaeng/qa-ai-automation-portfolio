{
  "name": "qa-ai-automation-portfolio",
  "version": "1.0.0",
  "description": "Professional Playwright + TypeScript QA automation portfolio with AI-augmented testing",
  "author": "Alfonso Hernandez",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "playwright test",
    "test:e2e": "playwright test --project=e2e",
    "test:api": "playwright test --project=api",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "report": "allure generate allure-results --clean -o allure-report && allure open allure-report",
    "agent:analyze": "ts-node src/agents/analyze.ts",
    "agent:story": "ts-node -r tsconfig-paths/register src/agents/story-analyzer.ts",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf allure-results allure-report test-results .auth dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "allure-playwright": "^3.0.0",
    "eslint": "^9.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.0"
  }
}
