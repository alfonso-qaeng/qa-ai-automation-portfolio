# Anthropic API — required for AI-agent tests and analysis scripts
ANTHROPIC_API_KEY=sk-ant-...

# Target apps
BASE_URL=https://www.saucedemo.com
API_BASE_URL=https://reqres.in

# reqres.in API key — free tier at https://reqres.in/signup
REQRES_API_KEY=reqres-free-v1-...

# SauceDemo credentials (used in auth setup)
SAUCE_USERNAME=standard_user
SAUCE_PASSWORD=secret_sauce

# CI flag — set automatically by GitHub Actions
CI=false
