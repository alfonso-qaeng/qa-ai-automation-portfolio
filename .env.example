# Anthropic API — optional. Controls which mode the story analyzer uses:
#   Not set → Manual mode: prints a ready-to-paste Claude Code prompt (free)
#   Set     → Automatic mode: calls Claude API directly and saves JSON report
# Leave empty to use Claude Code manually instead of the API.
ANTHROPIC_API_KEY=

# Target apps
BASE_URL=https://www.saucedemo.com
API_BASE_URL=https://reqres.in

# reqres.in API key — free tier at https://reqres.in/signup
REQRES_API_KEY=reqres-free-v1-...

# SauceDemo credentials (used in auth setup)
SAUCE_USERNAME=standard_user
SAUCE_PASSWORD=secret_sauce

# CI flag — set automatically by GitHub Actions
CI=false
